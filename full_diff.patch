+
+
+def test_status_buckets_daemon_runs(monkeypatch, capsys):
+    """cmd_status shows daemon runs under 'Active runs:' section."""
+    monkeypatch.setattr("supervisor.daemon.client.DaemonClient", _DaemonWithRuns)
