+from pathlib import Path
+from unittest.mock import MagicMock, patch
+
+from supervisor import app
+
+
+class _DaemonWithRuns:
+    def is_running(self):
+        return True
+
+    def status(self):
+        return {
+            "ok": True,
+            "runs": [
+                {
+                    "run_id": "run_d1",
+                    "pane_target": "%3",
+                    "top_state": "RUNNING",
+                    "current_node": "step_1",
+                    "status_reason": "working step_1",
+                },
+            ],
+        }
+
+
+class _DaemonStopped:
